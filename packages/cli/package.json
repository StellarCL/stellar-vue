{
  "name": "@stellar-vue-ui/cli",
  "version": "0.4.1",
  "description": "CLI tool for Stellar Vue UI",
  "author": "Terry McCann <terry@stellarcl.dev>",
  "license": "MIT",
  "homepage": "https://github.com/StellarCL/stellar-vue",
  "repository": {
    "type": "git",
    "url": "https://github.com/StellarCL/stellar-vue.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "vue",
    "vue3",
    "cli",
    "stellar-vue-ui",
    "component-library"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "stellar-ui": "./dist/index.js"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "generate": "tsx scripts/generate-templates.ts && tsx scripts/generate-theme-templates.ts",
    "prebuild": "tsx scripts/generate-templates.ts && tsx scripts/generate-theme-templates.ts",
    "build": "tsup src/index.ts --format cjs --dts --tsconfig tsconfig.build.json",
    "dev": "tsup src/index.ts --format cjs --dts --watch",
    "pretest": "tsx scripts/generate-templates.ts && tsx scripts/generate-theme-templates.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "diff": "^5.2.0",
    "execa": "^9.0.0",
    "fast-glob": "^3.3.0",
    "ora": "^8.0.0",
    "picocolors": "^1.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/diff": "^5.2.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
