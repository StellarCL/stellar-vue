{
  "name": "@stellar-vue-ui/animations",
  "version": "0.1.0",
  "description": "Animation primitives for Stellar Vue UI",
  "author": "Terry McCann <terry@stellarcl.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/StellarCL/stellar-vue.git",
    "directory": "packages/animations"
  },
  "keywords": [
    "vue",
    "vue3",
    "animations",
    "transitions",
    "motion"
  ],
  "homepage": "https://github.com/StellarCL/stellar-vue",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.config.build.ts && vue-tsc --project tsconfig.build.json",
    "dev": "vite build --config vite.config.build.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^25.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.0.0"
  }
}
